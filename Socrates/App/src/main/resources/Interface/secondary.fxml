<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.Separator?>
<?import javafx.scene.image.Image?>
<?import javafx.scene.image.ImageView?>
<?import javafx.scene.layout.VBox?>
<?import javafx.scene.text.Font?>

<VBox alignment="TOP_CENTER" prefHeight="730.0" prefWidth="640.0" spacing="14.0"
      xmlns="http://javafx.com/javafx/25"
      xmlns:fx="http://javafx.com/fxml/1"
      fx:controller="socratesGui.SecondaryController">

   <children>

      <!-- Logo Compensar -->
      <ImageView fitHeight="92.0" fitWidth="200.0" pickOnBounds="true" preserveRatio="true">
         <image><Image url="@compensarLog.jpg" /></image>
      </ImageView>

      <Label text="Acceso con Compensar">
         <font><Font name="System Bold Italic" size="20.0" /></font>
      </Label>

      <Separator prefWidth="260.0" />

      <!-- Indicador visual de redirección -->
      <Label text="🔗  Conectando con los servicios de Compensar..."
             style="-fx-text-fill: #2E6B7A; -fx-font-size: 13px;" wrapText="true" prefWidth="300.0"/>

      <Label text="Esta funcionalidad está disponible para afiliados activos de Compensar. Al continuar serás redirigido al portal de autenticación institucional."
             style="-fx-text-fill: #555555; -fx-font-size: 12px;"
             wrapText="true" prefWidth="300.0" alignment="CENTER"/>

      <!-- Logo grande Compensar como visual central -->
      <ImageView fitHeight="120.0" fitWidth="260.0" pickOnBounds="true" preserveRatio="true">
         <image><Image url="@CompensarLogo2.png" /></image>
      </ImageView>

      <Label text="Serás autenticado con tu cuenta institucional."
             style="-fx-text-fill: #888888; -fx-font-size: 11px; -fx-font-style: italic;"
             wrapText="true" prefWidth="280.0" alignment="CENTER"/>

      <Separator prefWidth="260.0" />

      <!-- Botón continuar (simulado) -->
      <Button mnemonicParsing="false"
              prefHeight="34.0" prefWidth="200.0"
              style="-fx-background-color: #2E6B7A; -fx-text-fill: white;
                     -fx-background-radius: 10; -fx-font-size: 13px; -fx-cursor: hand;"
              text="Continuar con Compensar" />

      <!-- Botón volver -->
      <Button fx:id="secondaryButton"
              mnemonicParsing="false"
              onAction="#switchToPrimary"
              prefHeight="30.0" prefWidth="130.0"
              style="-fx-background-color: transparent; -fx-text-fill: #2E6B7A;
                     -fx-border-color: #2E6B7A; -fx-border-radius: 8;
                     -fx-background-radius: 8; -fx-font-size: 12px; -fx-cursor: hand;"
              text="← Volver" />

   </children>

   <padding>
      <Insets bottom="20.0" left="20.0" right="20.0" top="20.0" />
   </padding>

</VBox>
