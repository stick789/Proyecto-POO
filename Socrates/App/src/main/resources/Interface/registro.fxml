<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.ComboBox?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.PasswordField?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.image.Image?>
<?import javafx.scene.image.ImageView?>
<?import javafx.scene.layout.VBox?>
<?import javafx.scene.text.Font?>

<VBox alignment="TOP_CENTER" prefHeight="680.0" prefWidth="460.0" spacing="8.0"
      xmlns="http://javafx.com/javafx/21"
      xmlns:fx="http://javafx.com/fxml/1"
      fx:controller="socratesGui.RegistroController"
      style="-fx-background-color: #f4f6f9;">

   <padding>
      <Insets bottom="24.0" left="40.0" right="40.0" top="20.0" />
   </padding>

   <children>

      <!-- Logo -->
      <ImageView fitHeight="70.0" fitWidth="160.0" pickOnBounds="true" preserveRatio="true">
         <image><Image url="@compensarLog.jpg" /></image>
      </ImageView>

      <!-- Título -->
      <Label alignment="CENTER" text="Crear cuenta"
             style="-fx-font-size: 20px; -fx-font-weight: bold; -fx-text-fill: #1a1a2e;">
         <font><Font name="System Bold" size="20.0" /></font>
      </Label>
      <Label text="Completa tus datos para registrarte en Sócrates"
             style="-fx-font-size: 12px; -fx-text-fill: #666666;" wrapText="true"
             alignment="CENTER" prefWidth="380.0"/>

      <!-- Nombre completo (persona) -->
      <Label text="Nombre completo"
             style="-fx-text-fill: #2E6B7A; -fx-font-weight: bold; -fx-font-size: 12px;" />
      <TextField fx:id="txtNombre"
                 promptText="Ej: Juan García"
                 prefWidth="380.0"
                 style="-fx-background-color: white; -fx-border-color: #2E6B7A;
                        -fx-border-radius: 6; -fx-background-radius: 6;
                        -fx-padding: 7 10 7 10; -fx-font-size: 13px;" />

      <!-- Correo (usuario) -->
      <Label text="Correo electrónico"
             style="-fx-text-fill: #2E6B7A; -fx-font-weight: bold; -fx-font-size: 12px;" />
      <TextField fx:id="txtEmail"
                 promptText="usuario@compensar.com"
                 prefWidth="380.0"
                 style="-fx-background-color: white; -fx-border-color: #2E6B7A;
                        -fx-border-radius: 6; -fx-background-radius: 6;
                        -fx-padding: 7 10 7 10; -fx-font-size: 13px;" />

      <!-- Tipo de documento -->
      <Label text="Tipo de documento"
             style="-fx-text-fill: #2E6B7A; -fx-font-weight: bold; -fx-font-size: 12px;" />
      <ComboBox fx:id="cmbTipoDocumento"
                prefWidth="380.0"
                promptText="Selecciona..."
                style="-fx-background-color: white; -fx-border-color: #2E6B7A;
                       -fx-border-radius: 6; -fx-background-radius: 6;
                       -fx-font-size: 13px;" />

      <!-- Número de documento -->
      <Label text="Número de documento"
             style="-fx-text-fill: #2E6B7A; -fx-font-weight: bold; -fx-font-size: 12px;" />
      <TextField fx:id="txtNumDocumento"
                 promptText="Ej: 1234567890"
                 prefWidth="380.0"
                 style="-fx-background-color: white; -fx-border-color: #2E6B7A;
                        -fx-border-radius: 6; -fx-background-radius: 6;
                        -fx-padding: 7 10 7 10; -fx-font-size: 13px;" />

      <!-- Contraseña -->
      <Label text="Contraseña"
             style="-fx-text-fill: #2E6B7A; -fx-font-weight: bold; -fx-font-size: 12px;" />
      <PasswordField fx:id="txtContrasena"
                     promptText="Mínimo 6 caracteres"
                     prefWidth="380.0"
                     style="-fx-background-color: white; -fx-border-color: #2E6B7A;
                            -fx-border-radius: 6; -fx-background-radius: 6;
                            -fx-padding: 7 10 7 10; -fx-font-size: 13px;" />

      <!-- Confirmar contraseña -->
      <Label text="Confirmar contraseña"
             style="-fx-text-fill: #2E6B7A; -fx-font-weight: bold; -fx-font-size: 12px;" />
      <PasswordField fx:id="txtConfirmar"
                     promptText="Repite tu contraseña"
                     prefWidth="380.0"
                     style="-fx-background-color: white; -fx-border-color: #2E6B7A;
                            -fx-border-radius: 6; -fx-background-radius: 6;
                            -fx-padding: 7 10 7 10; -fx-font-size: 13px;" />

      <!-- Mensaje de error -->
      <Label fx:id="lblError" text=""
             style="-fx-text-fill: #c0392b; -fx-font-size: 11px;"
             wrapText="true" prefWidth="380.0" />

      <!-- Botones -->
      <Button mnemonicParsing="false"
              prefHeight="35.0" prefWidth="380.0"
              onAction="#onRegistrar"
              style="-fx-background-color: #2E6B7A; -fx-text-fill: white;
                     -fx-background-radius: 10; -fx-font-size: 13px; -fx-cursor: hand;
                     -fx-font-weight: bold;"
              text="Crear cuenta" />

      <Button mnemonicParsing="false"
              prefHeight="30.0" prefWidth="380.0"
              onAction="#onCancelar"
              style="-fx-background-color: transparent; -fx-text-fill: #2E6B7A;
                     -fx-border-color: #2E6B7A; -fx-border-radius: 10;
                     -fx-background-radius: 10; -fx-font-size: 12px; -fx-cursor: hand;"
              text="Volver al inicio de sesión" />

   </children>
</VBox>
