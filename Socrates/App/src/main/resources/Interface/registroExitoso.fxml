<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.layout.VBox?>
<?import javafx.scene.text.Font?>

<VBox alignment="CENTER" prefHeight="320.0" prefWidth="420.0" spacing="14.0"
      xmlns="http://javafx.com/javafx/21"
      xmlns:fx="http://javafx.com/fxml/1"
      fx:controller="socratesGui.RegistroExitosoController"
      style="-fx-background-color: #f4f6f9;">

   <padding>
      <Insets bottom="30.0" left="40.0" right="40.0" top="30.0" />
   </padding>

   <children>

      <!-- Ícono de éxito (checkmark en texto) -->
      <Label text="✔"
             style="-fx-font-size: 48px; -fx-text-fill: #27ae60;" />

      <!-- Título -->
      <Label text="¡Registro exitoso!"
             style="-fx-font-size: 20px; -fx-font-weight: bold; -fx-text-fill: #1a1a2e;">
         <font><Font name="System Bold" size="20.0" /></font>
      </Label>

      <!-- Datos del usuario registrado -->
      <VBox spacing="6.0" alignment="CENTER"
            style="-fx-background-color: white; -fx-background-radius: 8;
                   -fx-padding: 16; -fx-effect: dropshadow(gaussian, rgba(0,0,0,0.08), 6, 0, 0, 2);"
            prefWidth="340.0">
         <Label text="Bienvenido/a:"
                style="-fx-font-size: 12px; -fx-text-fill: #888888;" />
         <Label fx:id="lblPersona"
                style="-fx-font-size: 16px; -fx-font-weight: bold; -fx-text-fill: #2E6B7A;"
                wrapText="true" alignment="CENTER" />
         <Label text="Usuario:"
                style="-fx-font-size: 12px; -fx-text-fill: #888888;" />
         <Label fx:id="lblUsuario"
                style="-fx-font-size: 14px; -fx-text-fill: #1a1a2e;"
                wrapText="true" alignment="CENTER" />
      </VBox>

      <!-- Instrucción -->
      <Label text="Ya puedes iniciar sesión con tu correo y contraseña."
             style="-fx-font-size: 12px; -fx-text-fill: #555555;"
             wrapText="true" alignment="CENTER" prefWidth="340.0" />

      <!-- Botón Aceptar -->
      <Button mnemonicParsing="false"
              prefHeight="35.0" prefWidth="340.0"
              onAction="#onAceptar"
              style="-fx-background-color: #2E6B7A; -fx-text-fill: white;
                     -fx-background-radius: 10; -fx-font-size: 13px; -fx-cursor: hand;
                     -fx-font-weight: bold;"
              text="Ir al inicio de sesión" />

   </children>
</VBox>
