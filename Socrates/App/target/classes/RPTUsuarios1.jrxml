	<dataset name="DatasetUsuario" uuid="8e077925-e5ca-43e1-8865-ddaabbaa6dca">
		<property name="com.jaspersoft.studio.data.sql.tables" value=""/>
		<property name="com.jaspersoft.studio.data.defaultdataadapter" value="proyecto_poo.jrdax"/>
		<query language="SQL"><![CDATA[SELECT 
    s.nombre AS nombre_sede,
    i.tipo,
    i.nombre AS nombre_instalacion,
    t.fechaHora,
    t.duracionMinutos,
    u.categoria,
    CASE 
        WHEN u.esAfiliado = 0 THEN 0
        WHEN u.categoria = 'C' THEN 50000
        WHEN u.categoria = 'B' THEN 35000
        WHEN u.categoria = 'A' THEN 20000
        ELSE 0
    END AS monto,
    CASE
        WHEN u.esAfiliado = 0 THEN 'GRATIS'
        ELSE 'POR PAGAR'
    END AS estadoPago
FROM turno t
JOIN instalacion i ON t.id_instalacion = i.idInstalacion
JOIN sede s ON i.idSede = s.idSede
JOIN usuarios u ON t.id_usuario = u.idusuario]]></query>
		<field name="nombre_sede" class="java.lang.String">
			<property name="com.jaspersoft.studio.field.name" value="nombre"/>
			<property name="com.jaspersoft.studio.field.label" value="nombre_sede"/>
