			<property name="com.jaspersoft.studio.field.tree.path" value="turno"/>
		</field>
		<field name="categoria" class="java.lang.String">
			<property name="com.jaspersoft.studio.field.name" value="categoria"/>
			<property name="com.jaspersoft.studio.field.label" value="categoria"/>
			<property name="com.jaspersoft.studio.field.tree.path" value="usuarios"/>
		</field>
		<field name="monto" class="java.lang.Integer">
			<property name="com.jaspersoft.studio.field.name" value="monto"/>
			<property name="com.jaspersoft.studio.field.label" value="monto"/>
		</field>
		<field name="estadoPago" class="java.lang.String">
			<property name="com.jaspersoft.studio.field.name" value="estadoPago"/>
			<property name="com.jaspersoft.studio.field.label" value="estadoPago"/>
		</field>
	</dataset>
	<query language="SQL"><![CDATA[SELECT 
    s.nombre AS nombre_sede,
    i.tipo,
    i.nombre AS nombre_instalacion,
    t.fechaHora,
    t.duracionMinutos,
    u.categoria,
    u.esAfiliado,
    per.nombre AS nombre_usuario,
    per.email AS email_usuario,
    per.numdocumento AS doc_usuario,
    per.tipodocumento AS tipodocumento,
    pa.monto AS monto,
    pa.estadoPago AS estadoPago
FROM turno t
JOIN instalacion i ON t.id_instalacion = i.idInstalacion
JOIN sede s ON i.idSede = s.idSede
JOIN usuarios u ON t.id_usuario = u.idusuario
JOIN persona per ON u.id_persona = per.id_persona
LEFT JOIN pagos pa ON u.idusuario = pa.idPago]]></query>
