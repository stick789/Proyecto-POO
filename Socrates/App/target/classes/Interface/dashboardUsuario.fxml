<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.ComboBox?>
<?import javafx.scene.control.DatePicker?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.MenuButton?>
<?import javafx.scene.control.ScrollPane?>
<?import javafx.scene.control.TableColumn?>
<?import javafx.scene.control.TableView?>
<?import javafx.scene.image.Image?>
<?import javafx.scene.image.ImageView?>
<?import javafx.scene.layout.BorderPane?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.VBox?>

<BorderPane prefHeight="800" prefWidth="1280" xmlns="http://javafx.com/javafx/25" xmlns:fx="http://javafx.com/fxml/1" fx:controller="socratesGui.Dashboardusuariocontroller">

    <!-- ═══════════════════ LEFT SIDEBAR ═══════════════════ -->
    <left>
        <VBox prefWidth="210" style="-fx-background-color: #E85D04;">

            <!-- Logo / Brand -->
            <VBox spacing="4" style="-fx-background-color: #C44D03;">
                <padding><Insets bottom="18" left="16" right="16" top="18" /></padding>
                <Label style="-fx-text-fill: white; -fx-font-size: 18; -fx-font-weight: bold;-fx cursor: hand;" onMouseClicked="#onInicio" >
               <graphic>
                  <ImageView accessibleRole="BUTTON" fitHeight="34.0" fitWidth="200.0">
                     <image>
                        <Image url="@socrates_logo_compacto.png" />
                     </image>
                  </ImageView>
               </graphic></Label>
                <Label style="-fx-text-fill: #FFD6A5; -fx-font-size: 10;" text="Centro Deportivo" />
            </VBox>

            <!-- User Info -->
            <VBox spacing="4" style="-fx-background-color: rgba(0,0,0,0.12);">
                <padding><Insets bottom="14" left="16" right="16" top="14" /></padding>
                <Label fx:id="lblNombreUsuario" style="-fx-text-fill: white; -fx-font-size: 13; -fx-font-weight: bold;" />
                <Label fx:id="lblEmailUsuario" style="-fx-text-fill: #FFD6A5; -fx-font-size: 10;" />
            </VBox>

            <!-- Nav Buttons -->
            <VBox spacing="2">
                <padding><Insets bottom="12" left="8" right="8" top="12" /></padding>

                <Button fx:id="btnNavInicio" alignment="CENTER_LEFT" onAction="#onInicio" prefWidth="194" style="-fx-background-color: transparent; -fx-text-fill: #FFD6A5; -fx-font-size: 12; -fx-padding: 10 20; -fx-cursor: hand;" text="🏠  Inicio" />
                <Button fx:id="btnNavAgendarTurno" alignment="CENTER_LEFT" onAction="#onAgendarTurno" prefWidth="194" style="-fx-background-color: #FF8C00; -fx-text-fill: white; -fx-font-size: 12; -fx-padding: 10 20; -fx-cursor: hand; -fx-background-radius: 6;" text="➕  Agendar Turno" />
                <Button fx:id="btnNavMisTurnos" alignment="CENTER_LEFT" onAction="#onMisTurnos" prefWidth="194" style="-fx-background-color: transparent; -fx-text-fill: #FFD6A5; -fx-font-size: 12; -fx-padding: 10 20; -fx-cursor: hand;" text="📅  Mis Turnos" />
                <Button fx:id="btnNavHistorial" alignment="CENTER_LEFT" onAction="#onHistorial" prefWidth="194" style="-fx-background-color: transparent; -fx-text-fill: #FFD6A5; -fx-font-size: 12; -fx-padding: 10 20; -fx-cursor: hand;" text="📋  Historial" />
                <Button fx:id="btnNavMisPagos" alignment="CENTER_LEFT" onAction="#onMisPagos" prefWidth="194" style="-fx-background-color: transparent; -fx-text-fill: #FFD6A5; -fx-font-size: 12; -fx-padding: 10 20; -fx-cursor: hand;" text="💳  Mis Pagos" />
                <Button fx:id="btnNavMisFacturas" alignment="CENTER_LEFT" onAction="#onMisFacturas" prefWidth="194" style="-fx-background-color: transparent; -fx-text-fill: #FFD6A5; -fx-font-size: 12; -fx-padding: 10 20; -fx-cursor: hand;" text="🧾  Mis Facturas" />
            </VBox>

            <!-- Spacer -->
            <VBox VBox.vgrow="ALWAYS" />

            <!-- Logout -->
            <Button fx:id="btnLogout" onAction="#onLogout" prefWidth="194" style="-fx-background-color: #C44D03; -fx-text-fill: white; -fx-padding: 10 20; -fx-cursor: hand; -fx-font-size: 12;" text="⬅  Cerrar Sesión">
                <VBox.margin><Insets bottom="20" left="8" right="8" /></VBox.margin>
            </Button>
        </VBox>
    </left>

    <!-- ═══════════════════ CENTER CONTENT ═══════════════════ -->
    <center>
        <VBox spacing="16" style="-fx-background-color: #FFF8F0;">
            <padding><Insets bottom="20" left="20" right="20" top="20" /></padding>

            <!-- Header -->
            <HBox alignment="CENTER_LEFT" style="-fx-background-color: white; -fx-background-radius: 8;                          -fx-effect: dropshadow(gaussian,rgba(232,93,4,0.12),6,0,0,2); -fx-padding: 14 20;">
                <Label fx:id="lblSeccion" style="-fx-font-size: 22; -fx-font-weight: bold; -fx-text-fill: #E85D04;" text="Inicio" />
                <HBox HBox.hgrow="ALWAYS" />
                <Label fx:id="lblFecha" style="-fx-font-size: 11; -fx-text-fill: #E85D04;" />
            </HBox>

            <!-- Mensaje global -->
            <Label fx:id="lblMsgGlobal" style="-fx-text-fill: #C44D03; -fx-font-size: 12;" text="" wrapText="true" />

            <!-- Panels Container -->
            <ScrollPane fitToWidth="true" style="-fx-background: transparent; -fx-background-color: transparent;" VBox.vgrow="ALWAYS">
                <VBox spacing="16">
                    <padding><Insets bottom="4" left="4" right="4" top="4" /></padding>

                    <!-- ── PANEL INICIO ── -->
                    <VBox fx:id="panelInicio" managed="true" spacing="20" visible="true">

                        <!-- Tarjetas resumen -->
                        <HBox spacing="16">
                            <!-- Próximo Turno -->
                            <VBox alignment="CENTER" spacing="5" style="-fx-background-color: white; -fx-background-radius: 8;                                          -fx-effect: dropshadow(gaussian,rgba(232,93,4,0.10),6,0,0,2);                                          -fx-padding: 20; -fx-border-color: #FFD6A5; -fx-border-radius: 8;" HBox.hgrow="ALWAYS">
                                <Label style="-fx-font-size: 12; -fx-text-fill: #E85D04;" text="Próximo Turno" />
                                <Label fx:id="lblProximoTurno" style="-fx-font-size: 13; -fx-font-weight: bold; -fx-text-fill: #C44D03; -fx-wrap-text: true;" text="Sin turnos" wrapText="true" />
                            </VBox>
                            <!-- Turnos Activos -->
                            <VBox alignment="CENTER" spacing="5" style="-fx-background-color: white; -fx-background-radius: 8;                                          -fx-effect: dropshadow(gaussian,rgba(232,93,4,0.10),6,0,0,2);                                          -fx-padding: 20; -fx-border-color: #FFD6A5; -fx-border-radius: 8;" HBox.hgrow="ALWAYS">
                                <Label style="-fx-font-size: 12; -fx-text-fill: #E85D04;" text="Turnos Activos" />
                                <Label fx:id="lblCountTurnos" style="-fx-font-size: 28; -fx-font-weight: bold; -fx-text-fill: #E85D04;" text="0" />
                            </VBox>
                            <!-- Pagos Pendientes -->
                            <VBox alignment="CENTER" spacing="5" style="-fx-background-color: white; -fx-background-radius: 8;                                          -fx-effect: dropshadow(gaussian,rgba(232,93,4,0.10),6,0,0,2);                                          -fx-padding: 20; -fx-border-color: #FFD6A5; -fx-border-radius: 8;" HBox.hgrow="ALWAYS">
                                <Label style="-fx-font-size: 12; -fx-text-fill: #E85D04;" text="Pagos Pendientes" />
                                <Label fx:id="lblCountPagos" style="-fx-font-size: 28; -fx-font-weight: bold; -fx-text-fill: #C44D03;" text="0" />
                            </VBox>
                            <!-- Estado Instalaciones -->
                            <VBox alignment="CENTER" spacing="5" style="-fx-background-color: white; -fx-background-radius: 8;                                          -fx-effect: dropshadow(gaussian,rgba(232,93,4,0.10),6,0,0,2);                                          -fx-padding: 20; -fx-border-color: #FFD6A5; -fx-border-radius: 8;" HBox.hgrow="ALWAYS">
                                <Label style="-fx-font-size: 12; -fx-text-fill: #E85D04;" text="Cupos Disponibles" />
                                <Label fx:id="lblCuposGim" style="-fx-font-size: 12; -fx-text-fill: #C44D03;" text="Gym: —" />
                                <Label fx:id="lblCuposPisc" style="-fx-font-size: 12; -fx-text-fill: #C44D03;" text="Piscina: —" />
                            </VBox>
                        </HBox>

                        <!-- Notificaciones -->
                        <VBox spacing="6" style="-fx-background-color: white; -fx-background-radius: 8;                                      -fx-effect: dropshadow(gaussian,rgba(232,93,4,0.10),6,0,0,2);                                      -fx-padding: 16; -fx-border-color: #FFD6A5; -fx-border-radius: 8;">
                            <Label style="-fx-font-size: 14; -fx-font-weight: bold; -fx-text-fill: #E85D04;" text="🔔  Notificaciones" />
                            <Label fx:id="lblNotificaciones" style="-fx-font-size: 12; -fx-text-fill: #555;" text="Sin notificaciones pendientes." wrapText="true" />
                        </VBox>

                        <!-- Acciones rápidas -->
                        <HBox spacing="12">
                            <Button onAction="#onAgendarTurno" style="-fx-background-color: #E85D04; -fx-text-fill: white;                                            -fx-font-size: 13; -fx-padding: 10 20; -fx-cursor: hand;                                            -fx-background-radius: 6;" text="➕  Agendar Turno" />
                            <Button onAction="#onMisTurnos" style="-fx-background-color: #C44D03; -fx-text-fill: white;                                            -fx-font-size: 13; -fx-padding: 10 20; -fx-cursor: hand;                                            -fx-background-radius: 6;" text="📅  Ver mis reservas" />
                        </HBox>
                    </VBox>

                    <!-- ── PANEL AGENDAR TURNO ── -->
                    <VBox fx:id="panelAgendarTurno" managed="false" spacing="14" style="-fx-background-color: white; -fx-background-radius: 8;                                  -fx-effect: dropshadow(gaussian,rgba(232,93,4,0.10),6,0,0,2);                                  -fx-padding: 24; -fx-border-color: #FFD6A5; -fx-border-radius: 8;" visible="false">

                        <Label style="-fx-font-size: 16; -fx-font-weight: bold; -fx-text-fill: #E85D04;" text="Nueva Reserva" />

                        <!-- Paso 1: Instalación -->
                        <VBox spacing="6" style="-fx-border-color: #FFD6A5; -fx-border-radius: 6; -fx-padding: 14;                                      -fx-background-color: #FFF8F0; -fx-background-radius: 6;">
                            <Label style="-fx-font-size: 13; -fx-font-weight: bold; -fx-text-fill: #E85D04;" text="1. Selecciona la instalación" />
                            <HBox spacing="10">
                                <Button fx:id="btnSelGimnasio" onAction="#onSelGimnasio" prefHeight="60" prefWidth="180" style="-fx-background-color: white; -fx-border-color: #E85D04;                                                -fx-border-radius: 6; -fx-background-radius: 6;                                                -fx-font-size: 13; -fx-cursor: hand; -fx-text-fill: #E85D04;" text="🏋️  Gimnasio" />
                                <Button fx:id="btnSelPiscina" onAction="#onSelPiscina" prefHeight="60" prefWidth="180" style="-fx-background-color: white; -fx-border-color: #E85D04;                                                -fx-border-radius: 6; -fx-background-radius: 6;                                                -fx-font-size: 13; -fx-cursor: hand; -fx-text-fill: #E85D04;" text="🏊  Piscina" />
                            </HBox>
                            <Label fx:id="lblCapacidadInstalacion" style="-fx-font-size: 11; -fx-text-fill: #C44D03;" text="" />
                        </VBox>

                        <!-- Paso 1b: Entrenador (gimnasio o piscina) -->
                        <VBox fx:id="panelEntrenador" managed="false" spacing="6" style="-fx-border-color: #FFD6A5; -fx-border-radius: 6; -fx-padding: 14;                                      -fx-background-color: #FFF3E0; -fx-background-radius: 6;" visible="false">
                            <Label style="-fx-font-size: 13; -fx-font-weight: bold; -fx-text-fill: #E85D04;" text="¿Deseas un entrenador?" />
                            <Label style="-fx-font-size: 11; -fx-text-fill: #888;" text="Un entrenador te guiará durante tu sesión" />
                            <HBox spacing="10">
                                <Button fx:id="btnConEntrenador" onAction="#onConEntrenador" prefHeight="44" style="-fx-background-color: white; -fx-border-color: #E85D04;                                                -fx-border-radius: 6; -fx-background-radius: 6;                                                -fx-font-size: 12; -fx-cursor: hand; -fx-text-fill: #E85D04;" text="✅  Sí, quiero entrenador" />
                                <Button fx:id="btnSinEntrenador" onAction="#onSinEntrenador" prefHeight="44" style="-fx-background-color: white; -fx-border-color: #aaa;                                                -fx-border-radius: 6; -fx-background-radius: 6;                                                -fx-font-size: 12; -fx-cursor: hand; -fx-text-fill: #555;" text="❌  No, iré solo" />
                            </HBox>
                            <Label fx:id="lblEntrenadorSeleccionado" style="-fx-font-size: 11; -fx-text-fill: #C44D03;" text="" />
                        </VBox>

                        <!-- Paso 2: Fecha -->
                        <VBox spacing="6" style="-fx-border-color: #FFD6A5; -fx-border-radius: 6; -fx-padding: 14;                                      -fx-background-color: #FFF8F0; -fx-background-radius: 6;">
                            <Label style="-fx-font-size: 13; -fx-font-weight: bold; -fx-text-fill: #E85D04;" text="2. Selecciona la fecha" />
                            <DatePicker fx:id="dateFecha" prefWidth="220" style="-fx-font-size: 12;" />
                        </VBox>

                        <!-- Paso 3: Hora y duración -->
                        <VBox spacing="6" style="-fx-border-color: #FFD6A5; -fx-border-radius: 6; -fx-padding: 14;                                      -fx-background-color: #FFF8F0; -fx-background-radius: 6;">
                            <Label style="-fx-font-size: 13; -fx-font-weight: bold; -fx-text-fill: #E85D04;" text="3. Hora de inicio y duración" />
                            <HBox alignment="CENTER_LEFT" spacing="20">
                                <VBox spacing="4">
                                    <Label style="-fx-font-size: 12;" text="Hora de inicio:" />
                                    <ComboBox fx:id="cmbHora" prefWidth="130" style="-fx-font-size: 12;" />
                                </VBox>
                                <VBox spacing="4">
                                    <Label style="-fx-font-size: 12;" text="Duración (minutos):" />
                                    <ComboBox fx:id="cmbDuracion" prefWidth="130" style="-fx-font-size: 12;" />
                                </VBox>
                            </HBox>
                            <Label fx:id="lblDisponibilidad" style="-fx-font-size: 11; -fx-text-fill: #E85D04;" text="" wrapText="true" />
                        </VBox>

                        <!-- Carril (solo piscina) -->
                        <VBox fx:id="panelCarril" managed="false" spacing="6" style="-fx-border-color: #FFD6A5; -fx-border-radius: 6; -fx-padding: 14;                                      -fx-background-color: #FFF8F0; -fx-background-radius: 6;" visible="false">
                            <Label style="-fx-font-size: 13; -fx-font-weight: bold; -fx-text-fill: #E85D04;" text="4. Carril asignado" />
                            <HBox alignment="CENTER_LEFT" spacing="12">
                                <ComboBox fx:id="cmbCarril" prefWidth="160" style="-fx-font-size: 12;" />
                                <Button onAction="#onVerMapaPiscina" style="-fx-background-color: #E85D04; -fx-text-fill: white;                                                -fx-font-size: 11; -fx-padding: 8 14; -fx-cursor: hand;                                                -fx-background-radius: 6;" text="🏊 Ver mapa de piscina" />
                            </HBox>
                            <!-- Ocupación por carril -->
                            <Label fx:id="lblOcupacionCarril" style="-fx-font-size: 12; -fx-text-fill: #C44D03; -fx-font-weight: bold;" text="" />
                        </VBox>

                        <!-- Resumen y confirmar -->
                        <VBox fx:id="panelResumen" managed="false" spacing="6" style="-fx-background-color: #FFF3E0; -fx-border-color: #E85D04;                                      -fx-border-radius: 6; -fx-padding: 14;" visible="false">
                            <Label style="-fx-font-size: 13; -fx-font-weight: bold; -fx-text-fill: #E85D04;" text="Resumen de tu reserva" />
                            <Label fx:id="lblResumen" style="-fx-font-size: 12; -fx-text-fill: #333;" text="" wrapText="true" />
                        </VBox>

                        <Label fx:id="lblErrorAgendar" style="-fx-text-fill: #C44D03; -fx-font-size: 12;" text="" wrapText="true" />

                        <HBox spacing="10">
                            <Button onAction="#onConfirmarTurno" style="-fx-background-color: #E85D04; -fx-text-fill: white;                                            -fx-font-size: 13; -fx-padding: 10 20; -fx-cursor: hand;                                            -fx-background-radius: 6;" text="✔  Confirmar Reserva" />
                            <Button onAction="#onVerificarDisponibilidad" style="-fx-background-color: #FF8C00; -fx-text-fill: white;                                            -fx-font-size: 12; -fx-padding: 10 18; -fx-cursor: hand;                                            -fx-background-radius: 6;" text="Verificar disponibilidad" />
                            <Button onAction="#onInicio" style="-fx-background-color: transparent; -fx-border-color: #aaa;                                            -fx-border-radius: 6; -fx-background-radius: 6;                                            -fx-font-size: 12; -fx-padding: 10 16; -fx-cursor: hand;" text="Cancelar" />
                        </HBox>
                    </VBox>

                    <!-- ── PANEL MIS TURNOS ── -->
                    <VBox fx:id="panelTurnos" managed="false" spacing="10" style="-fx-background-color: white; -fx-background-radius: 8;                                  -fx-effect: dropshadow(gaussian,rgba(232,93,4,0.10),6,0,0,2);                                  -fx-padding: 20; -fx-border-color: #FFD6A5; -fx-border-radius: 8;" visible="false">
                        <Label style="-fx-font-size: 14; -fx-font-weight: bold; -fx-text-fill: #E85D04;" text="Mis Turnos Activos" />
                        <TableView fx:id="tablaTurnos" prefHeight="420" VBox.vgrow="ALWAYS">
                            <columns>
                                <TableColumn fx:id="colTurnoId" prefWidth="50" text="ID" />
                                <TableColumn fx:id="colTurnoFecha" prefWidth="140" text="Fecha" />
                                <TableColumn fx:id="colTurnoDuracion" prefWidth="80" text="Duración" />
                                <TableColumn fx:id="colTurnoInstalacion" prefWidth="120" text="Instalación" />
                                <TableColumn fx:id="colTurnoCapacidad" prefWidth="100" text="Ocupación" />
                                <TableColumn fx:id="colTurnoEstado" prefWidth="100" text="Estado" />
                                <TableColumn fx:id="colTurnoCarril" prefWidth="70" text="Carril" />
                            </columns>
                        </TableView>
                        <HBox alignment="CENTER_LEFT" spacing="10">
                            <Button fx:id="btnCancelarTurno" onAction="#onCancelarTurno" style="-fx-background-color: #E85D04; -fx-text-fill: white;                                            -fx-padding: 8 16; -fx-background-radius: 4; -fx-cursor: hand;" text="✕  Cancelar turno" />
                            <Label fx:id="lblMsgTurnos" style="-fx-text-fill: #C44D03; -fx-font-size: 12;" />
                        </HBox>
                    </VBox>

                    <!-- ── PANEL HISTORIAL ── -->
                    <VBox fx:id="panelHistorial" managed="false" spacing="10" style="-fx-background-color: white; -fx-background-radius: 8;                                  -fx-effect: dropshadow(gaussian,rgba(232,93,4,0.10),6,0,0,2);                                  -fx-padding: 20; -fx-border-color: #FFD6A5; -fx-border-radius: 8;" visible="false">
                        <Label style="-fx-font-size: 14; -fx-font-weight: bold; -fx-text-fill: #E85D04;" text="Historial de Turnos" />
                        <TableView fx:id="tablaHistorial" prefHeight="380" VBox.vgrow="ALWAYS">
                            <columns>
                                <TableColumn fx:id="colHistId" prefWidth="50" text="ID" />
                                <TableColumn fx:id="colHistFecha" prefWidth="140" text="Fecha" />
                                <TableColumn fx:id="colHistInstalacion" prefWidth="120" text="Instalación" />
                                <TableColumn fx:id="colHistDuracion" prefWidth="80" text="Duración" />
                                <TableColumn fx:id="colHistEstado" prefWidth="110" text="Estado" />
                            </columns>
                        </TableView>
                        <Label fx:id="lblMsgHistorial" style="-fx-text-fill: gray; -fx-font-size: 12;" text="" />
                    </VBox>

                    <!-- ── PANEL MIS PAGOS ── -->
                    <VBox fx:id="panelPagos" managed="false" spacing="10" style="-fx-background-color: white; -fx-background-radius: 8;                                  -fx-effect: dropshadow(gaussian,rgba(232,93,4,0.10),6,0,0,2);                                  -fx-padding: 20; -fx-border-color: #FFD6A5; -fx-border-radius: 8;" visible="false">
                        <Label style="-fx-font-size: 14; -fx-font-weight: bold; -fx-text-fill: #E85D04;" text="Mis Pagos" />
                        <TableView fx:id="tablaPagos" prefHeight="420" VBox.vgrow="ALWAYS">
                            <columns>
                                <TableColumn fx:id="colPagoId" prefWidth="55" text="ID" />
                                <TableColumn fx:id="colPagoTurno" prefWidth="75" text="Turno" />
                                <TableColumn fx:id="colPagoMonto" prefWidth="120" text="Monto" />
                                <TableColumn fx:id="colPagoMetodo" prefWidth="130" text="Método" />
                                <TableColumn fx:id="colPagoEstado" prefWidth="120" text="Estado" />
                                <TableColumn fx:id="colPagoFecha" prefWidth="180" text="Fecha" />
                            </columns>
                        </TableView>
                                          <HBox alignment="CENTER_RIGHT" spacing="8" style="-fx-padding: 8 0 0 0;">
                                                 <MenuButton fx:id="menuFacturas" style="-fx-background-color: #E85D04; -fx-text-fill: white; -fx-font-size: 12; -fx-padding: 8 14; -fx-cursor: hand; -fx-background-radius: 6;" text="🧾  Ver Facturas" />
                                          </HBox>
                        <Label fx:id="lblMsgPagos" style="-fx-text-fill: #C44D03; -fx-font-size: 12;" text="" />
                    </VBox>

                </VBox>
            </ScrollPane>
        </VBox>
    </center>
</BorderPane>
