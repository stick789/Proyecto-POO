<?xml version="1.0" encoding="UTF-8"?>
<?import javafx.scene.layout.BorderPane?>
<?import javafx.scene.layout.VBox?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.TableView?>
<?import javafx.scene.control.TableColumn?>
<?import javafx.scene.control.ScrollPane?>
<?import javafx.scene.control.ComboBox?>
<?import javafx.scene.control.DatePicker?>
<?import javafx.scene.control.Spinner?>
<?import javafx.geometry.Insets?>

<BorderPane prefWidth="1280" prefHeight="800"
            xmlns="http://javafx.com/javafx/21"
            xmlns:fx="http://javafx.com/fxml/1"
            fx:controller="socratesGui.Dashboardusuariocontroller">

    <!-- ═══════════════════ LEFT SIDEBAR ═══════════════════ -->
    <left>
        <VBox prefWidth="210" style="-fx-background-color: #E85D04;">

            <!-- Logo / Brand -->
            <VBox spacing="4" style="-fx-background-color: #C44D03;">
                <padding><Insets top="18" right="16" bottom="18" left="16"/></padding>
                <Label text="SÓCRATES"
                       style="-fx-text-fill: white; -fx-font-size: 18; -fx-font-weight: bold;"/>
                <Label text="Centro Deportivo"
                       style="-fx-text-fill: #FFD6A5; -fx-font-size: 10;"/>
            </VBox>

            <!-- User Info -->
            <VBox spacing="4" style="-fx-background-color: rgba(0,0,0,0.12);">
                <padding><Insets top="14" right="16" bottom="14" left="16"/></padding>
                <Label fx:id="lblNombreUsuario"
                       style="-fx-text-fill: white; -fx-font-size: 13; -fx-font-weight: bold;"/>
                <Label fx:id="lblEmailUsuario"
                       style="-fx-text-fill: #FFD6A5; -fx-font-size: 10;"/>
            </VBox>

            <!-- Nav Buttons -->
            <VBox spacing="2">
                <padding><Insets top="12" right="8" bottom="12" left="8"/></padding>

                <Button fx:id="btnNavInicio"       onAction="#onInicio"       text="🏠  Inicio"
                        prefWidth="194" alignment="CENTER_LEFT"
                        style="-fx-background-color: transparent; -fx-text-fill: #FFD6A5; -fx-font-size: 12; -fx-padding: 10 20; -fx-cursor: hand;"/>
                <Button fx:id="btnNavAgendarTurno" onAction="#onAgendarTurno" text="➕  Agendar Turno"
                        prefWidth="194" alignment="CENTER_LEFT"
                        style="-fx-background-color: #FF8C00; -fx-text-fill: white; -fx-font-size: 12; -fx-padding: 10 20; -fx-cursor: hand; -fx-background-radius: 6;"/>
                <Button fx:id="btnNavMisTurnos"    onAction="#onMisTurnos"    text="📅  Mis Turnos"
                        prefWidth="194" alignment="CENTER_LEFT"
                        style="-fx-background-color: transparent; -fx-text-fill: #FFD6A5; -fx-font-size: 12; -fx-padding: 10 20; -fx-cursor: hand;"/>
                <Button fx:id="btnNavHistorial"    onAction="#onHistorial"    text="📋  Historial"
                        prefWidth="194" alignment="CENTER_LEFT"
                        style="-fx-background-color: transparent; -fx-text-fill: #FFD6A5; -fx-font-size: 12; -fx-padding: 10 20; -fx-cursor: hand;"/>
                <Button fx:id="btnNavMisPagos"     onAction="#onMisPagos"     text="💳  Mis Pagos"
                        prefWidth="194" alignment="CENTER_LEFT"
                        style="-fx-background-color: transparent; -fx-text-fill: #FFD6A5; -fx-font-size: 12; -fx-padding: 10 20; -fx-cursor: hand;"/>
            </VBox>

            <!-- Spacer -->
            <VBox VBox.vgrow="ALWAYS"/>

            <!-- Logout -->
            <Button fx:id="btnLogout" onAction="#onLogout" text="⬅  Cerrar Sesión"
                    prefWidth="194"
                    style="-fx-background-color: #C44D03; -fx-text-fill: white; -fx-padding: 10 20; -fx-cursor: hand; -fx-font-size: 12;">
                <VBox.margin><Insets bottom="20" left="8" right="8"/></VBox.margin>
            </Button>
        </VBox>
    </left>

    <!-- ═══════════════════ CENTER CONTENT ═══════════════════ -->
    <center>
        <VBox style="-fx-background-color: #FFF8F0;" spacing="16">
            <padding><Insets top="20" right="20" bottom="20" left="20"/></padding>

            <!-- Header -->
            <HBox alignment="CENTER_LEFT"
                  style="-fx-background-color: white; -fx-background-radius: 8;
                         -fx-effect: dropshadow(gaussian,rgba(232,93,4,0.12),6,0,0,2); -fx-padding: 14 20;">
                <Label fx:id="lblSeccion" text="Inicio"
                       style="-fx-font-size: 22; -fx-font-weight: bold; -fx-text-fill: #E85D04;"/>
                <HBox HBox.hgrow="ALWAYS"/>
                <Label fx:id="lblFecha"
                       style="-fx-font-size: 11; -fx-text-fill: #E85D04;"/>
            </HBox>

            <!-- Mensaje global -->
            <Label fx:id="lblMsgGlobal" text=""
                   style="-fx-text-fill: #C44D03; -fx-font-size: 12;" wrapText="true"/>

            <!-- Panels Container -->
            <ScrollPane VBox.vgrow="ALWAYS" fitToWidth="true"
                        style="-fx-background: transparent; -fx-background-color: transparent;">
                <VBox spacing="16">
                    <padding><Insets top="4" right="4" bottom="4" left="4"/></padding>

                    <!-- ── PANEL INICIO ── -->
                    <VBox fx:id="panelInicio" visible="true" managed="true" spacing="20">

                        <!-- Tarjetas resumen -->
                        <HBox spacing="16">
                            <!-- Próximo Turno -->
                            <VBox spacing="5" alignment="CENTER"
                                  style="-fx-background-color: white; -fx-background-radius: 8;
                                         -fx-effect: dropshadow(gaussian,rgba(232,93,4,0.10),6,0,0,2);
                                         -fx-padding: 20; -fx-border-color: #FFD6A5; -fx-border-radius: 8;"
                                  HBox.hgrow="ALWAYS">
                                <Label text="Próximo Turno" style="-fx-font-size: 12; -fx-text-fill: #E85D04;"/>
                                <Label fx:id="lblProximoTurno" text="Sin turnos"
                                       style="-fx-font-size: 13; -fx-font-weight: bold; -fx-text-fill: #C44D03; -fx-wrap-text: true;"
                                       wrapText="true"/>
                            </VBox>
                            <!-- Turnos Activos -->
                            <VBox spacing="5" alignment="CENTER"
                                  style="-fx-background-color: white; -fx-background-radius: 8;
                                         -fx-effect: dropshadow(gaussian,rgba(232,93,4,0.10),6,0,0,2);
                                         -fx-padding: 20; -fx-border-color: #FFD6A5; -fx-border-radius: 8;"
                                  HBox.hgrow="ALWAYS">
                                <Label text="Turnos Activos" style="-fx-font-size: 12; -fx-text-fill: #E85D04;"/>
                                <Label fx:id="lblCountTurnos" text="0"
                                       style="-fx-font-size: 28; -fx-font-weight: bold; -fx-text-fill: #E85D04;"/>
                            </VBox>
                            <!-- Pagos Pendientes -->
                            <VBox spacing="5" alignment="CENTER"
                                  style="-fx-background-color: white; -fx-background-radius: 8;
                                         -fx-effect: dropshadow(gaussian,rgba(232,93,4,0.10),6,0,0,2);
                                         -fx-padding: 20; -fx-border-color: #FFD6A5; -fx-border-radius: 8;"
                                  HBox.hgrow="ALWAYS">
                                <Label text="Pagos Pendientes" style="-fx-font-size: 12; -fx-text-fill: #E85D04;"/>
                                <Label fx:id="lblCountPagos" text="0"
                                       style="-fx-font-size: 28; -fx-font-weight: bold; -fx-text-fill: #C44D03;"/>
                            </VBox>
                            <!-- Estado Instalaciones -->
                            <VBox spacing="5" alignment="CENTER"
                                  style="-fx-background-color: white; -fx-background-radius: 8;
                                         -fx-effect: dropshadow(gaussian,rgba(232,93,4,0.10),6,0,0,2);
                                         -fx-padding: 20; -fx-border-color: #FFD6A5; -fx-border-radius: 8;"
                                  HBox.hgrow="ALWAYS">
                                <Label text="Cupos Disponibles" style="-fx-font-size: 12; -fx-text-fill: #E85D04;"/>
                                <Label fx:id="lblCuposGim" text="Gym: —"
                                       style="-fx-font-size: 12; -fx-text-fill: #C44D03;"/>
                                <Label fx:id="lblCuposPisc" text="Piscina: —"
                                       style="-fx-font-size: 12; -fx-text-fill: #C44D03;"/>
                            </VBox>
                        </HBox>

                        <!-- Notificaciones -->
                        <VBox spacing="6"
                              style="-fx-background-color: white; -fx-background-radius: 8;
                                     -fx-effect: dropshadow(gaussian,rgba(232,93,4,0.10),6,0,0,2);
                                     -fx-padding: 16; -fx-border-color: #FFD6A5; -fx-border-radius: 8;">
                            <Label text="🔔  Notificaciones"
                                   style="-fx-font-size: 14; -fx-font-weight: bold; -fx-text-fill: #E85D04;"/>
                            <Label fx:id="lblNotificaciones" text="Sin notificaciones pendientes."
                                   style="-fx-font-size: 12; -fx-text-fill: #555;" wrapText="true"/>
                        </VBox>

                        <!-- Acciones rápidas -->
                        <HBox spacing="12">
                            <Button text="➕  Agendar Turno" onAction="#onAgendarTurno"
                                    style="-fx-background-color: #E85D04; -fx-text-fill: white;
                                           -fx-font-size: 13; -fx-padding: 10 20; -fx-cursor: hand;
                                           -fx-background-radius: 6;"/>
                            <Button text="📅  Ver mis reservas" onAction="#onMisTurnos"
                                    style="-fx-background-color: #C44D03; -fx-text-fill: white;
                                           -fx-font-size: 13; -fx-padding: 10 20; -fx-cursor: hand;
                                           -fx-background-radius: 6;"/>
                        </HBox>
                    </VBox>

                    <!-- ── PANEL AGENDAR TURNO ── -->
                    <VBox fx:id="panelAgendarTurno" visible="false" managed="false" spacing="14"
                          style="-fx-background-color: white; -fx-background-radius: 8;
                                 -fx-effect: dropshadow(gaussian,rgba(232,93,4,0.10),6,0,0,2);
                                 -fx-padding: 24; -fx-border-color: #FFD6A5; -fx-border-radius: 8;">

                        <Label text="Nueva Reserva"
                               style="-fx-font-size: 16; -fx-font-weight: bold; -fx-text-fill: #E85D04;"/>

                        <!-- Paso 1: Instalación -->
                        <VBox spacing="6"
                              style="-fx-border-color: #FFD6A5; -fx-border-radius: 6; -fx-padding: 14;
                                     -fx-background-color: #FFF8F0; -fx-background-radius: 6;">
                            <Label text="1. Selecciona la instalación"
                                   style="-fx-font-size: 13; -fx-font-weight: bold; -fx-text-fill: #E85D04;"/>
                            <HBox spacing="10">
                                <Button fx:id="btnSelGimnasio" text="🏋️  Gimnasio" onAction="#onSelGimnasio"
                                        prefWidth="180" prefHeight="60"
                                        style="-fx-background-color: white; -fx-border-color: #E85D04;
                                               -fx-border-radius: 6; -fx-background-radius: 6;
                                               -fx-font-size: 13; -fx-cursor: hand; -fx-text-fill: #E85D04;"/>
                                <Button fx:id="btnSelPiscina" text="🏊  Piscina" onAction="#onSelPiscina"
                                        prefWidth="180" prefHeight="60"
                                        style="-fx-background-color: white; -fx-border-color: #E85D04;
                                               -fx-border-radius: 6; -fx-background-radius: 6;
                                               -fx-font-size: 13; -fx-cursor: hand; -fx-text-fill: #E85D04;"/>
                            </HBox>
                            <Label fx:id="lblCapacidadInstalacion" text=""
                                   style="-fx-font-size: 11; -fx-text-fill: #C44D03;"/>
                        </VBox>

                        <!-- Paso 1b: Entrenador (gimnasio o piscina) -->
                        <VBox fx:id="panelEntrenador" spacing="6" visible="false" managed="false"
                              style="-fx-border-color: #FFD6A5; -fx-border-radius: 6; -fx-padding: 14;
                                     -fx-background-color: #FFF3E0; -fx-background-radius: 6;">
                            <Label text="¿Deseas un entrenador?"
                                   style="-fx-font-size: 13; -fx-font-weight: bold; -fx-text-fill: #E85D04;"/>
                            <Label text="Un entrenador te guiará durante tu sesión"
                                   style="-fx-font-size: 11; -fx-text-fill: #888;"/>
                            <HBox spacing="10">
                                <Button fx:id="btnConEntrenador" text="✅  Sí, quiero entrenador"
                                        onAction="#onConEntrenador"
                                        prefHeight="44"
                                        style="-fx-background-color: white; -fx-border-color: #E85D04;
                                               -fx-border-radius: 6; -fx-background-radius: 6;
                                               -fx-font-size: 12; -fx-cursor: hand; -fx-text-fill: #E85D04;"/>
                                <Button fx:id="btnSinEntrenador" text="❌  No, iré solo"
                                        onAction="#onSinEntrenador"
                                        prefHeight="44"
                                        style="-fx-background-color: white; -fx-border-color: #aaa;
                                               -fx-border-radius: 6; -fx-background-radius: 6;
                                               -fx-font-size: 12; -fx-cursor: hand; -fx-text-fill: #555;"/>
                            </HBox>
                            <Label fx:id="lblEntrenadorSeleccionado" text=""
                                   style="-fx-font-size: 11; -fx-text-fill: #C44D03;"/>
                        </VBox>

                        <!-- Paso 2: Fecha -->
                        <VBox spacing="6"
                              style="-fx-border-color: #FFD6A5; -fx-border-radius: 6; -fx-padding: 14;
                                     -fx-background-color: #FFF8F0; -fx-background-radius: 6;">
                            <Label text="2. Selecciona la fecha"
                                   style="-fx-font-size: 13; -fx-font-weight: bold; -fx-text-fill: #E85D04;"/>
                            <DatePicker fx:id="dateFecha" prefWidth="220"
                                        style="-fx-font-size: 12;"/>
                        </VBox>

                        <!-- Paso 3: Hora y duración -->
                        <VBox spacing="6"
                              style="-fx-border-color: #FFD6A5; -fx-border-radius: 6; -fx-padding: 14;
                                     -fx-background-color: #FFF8F0; -fx-background-radius: 6;">
                            <Label text="3. Hora de inicio y duración"
                                   style="-fx-font-size: 13; -fx-font-weight: bold; -fx-text-fill: #E85D04;"/>
                            <HBox spacing="20" alignment="CENTER_LEFT">
                                <VBox spacing="4">
                                    <Label text="Hora de inicio:" style="-fx-font-size: 12;"/>
                                    <ComboBox fx:id="cmbHora" prefWidth="130"
                                              style="-fx-font-size: 12;"/>
                                </VBox>
                                <VBox spacing="4">
                                    <Label text="Duración (minutos):" style="-fx-font-size: 12;"/>
                                    <ComboBox fx:id="cmbDuracion" prefWidth="130"
                                              style="-fx-font-size: 12;"/>
                                </VBox>
                            </HBox>
                            <Label fx:id="lblDisponibilidad" text=""
                                   style="-fx-font-size: 11; -fx-text-fill: #E85D04;" wrapText="true"/>
                        </VBox>

                        <!-- Carril (solo piscina) -->
                        <VBox fx:id="panelCarril" spacing="6" visible="false" managed="false"
                              style="-fx-border-color: #FFD6A5; -fx-border-radius: 6; -fx-padding: 14;
                                     -fx-background-color: #FFF8F0; -fx-background-radius: 6;">
                            <Label text="4. Carril asignado"
                                   style="-fx-font-size: 13; -fx-font-weight: bold; -fx-text-fill: #E85D04;"/>
                            <HBox spacing="12" alignment="CENTER_LEFT">
                                <ComboBox fx:id="cmbCarril" prefWidth="160" style="-fx-font-size: 12;"/>
                                <Button text="🏊 Ver mapa de piscina" onAction="#onVerMapaPiscina"
                                        style="-fx-background-color: #E85D04; -fx-text-fill: white;
                                               -fx-font-size: 11; -fx-padding: 8 14; -fx-cursor: hand;
                                               -fx-background-radius: 6;"/>
                            </HBox>
                            <!-- Ocupación por carril -->
                            <Label fx:id="lblOcupacionCarril" text=""
                                   style="-fx-font-size: 12; -fx-text-fill: #C44D03; -fx-font-weight: bold;"/>
                        </VBox>

                        <!-- Resumen y confirmar -->
                        <VBox fx:id="panelResumen" spacing="6" visible="false" managed="false"
                              style="-fx-background-color: #FFF3E0; -fx-border-color: #E85D04;
                                     -fx-border-radius: 6; -fx-padding: 14;">
                            <Label text="Resumen de tu reserva"
                                   style="-fx-font-size: 13; -fx-font-weight: bold; -fx-text-fill: #E85D04;"/>
                            <Label fx:id="lblResumen" text="" wrapText="true"
                                   style="-fx-font-size: 12; -fx-text-fill: #333;"/>
                        </VBox>

                        <Label fx:id="lblErrorAgendar" text=""
                               style="-fx-text-fill: #C44D03; -fx-font-size: 12;" wrapText="true"/>

                        <HBox spacing="10">
                            <Button text="✔  Confirmar Reserva" onAction="#onConfirmarTurno"
                                    style="-fx-background-color: #E85D04; -fx-text-fill: white;
                                           -fx-font-size: 13; -fx-padding: 10 20; -fx-cursor: hand;
                                           -fx-background-radius: 6;"/>
                            <Button text="Verificar disponibilidad" onAction="#onVerificarDisponibilidad"
                                    style="-fx-background-color: #FF8C00; -fx-text-fill: white;
                                           -fx-font-size: 12; -fx-padding: 10 18; -fx-cursor: hand;
                                           -fx-background-radius: 6;"/>
                            <Button text="Cancelar" onAction="#onInicio"
                                    style="-fx-background-color: transparent; -fx-border-color: #aaa;
                                           -fx-border-radius: 6; -fx-background-radius: 6;
                                           -fx-font-size: 12; -fx-padding: 10 16; -fx-cursor: hand;"/>
                        </HBox>
                    </VBox>

                    <!-- ── PANEL MIS TURNOS ── -->
                    <VBox fx:id="panelTurnos" visible="false" managed="false" spacing="10"
                          style="-fx-background-color: white; -fx-background-radius: 8;
                                 -fx-effect: dropshadow(gaussian,rgba(232,93,4,0.10),6,0,0,2);
                                 -fx-padding: 20; -fx-border-color: #FFD6A5; -fx-border-radius: 8;">
                        <Label text="Mis Turnos Activos"
                               style="-fx-font-size: 14; -fx-font-weight: bold; -fx-text-fill: #E85D04;"/>
                        <TableView fx:id="tablaTurnos" VBox.vgrow="ALWAYS" prefHeight="420">
                            <columns>
                                <TableColumn fx:id="colTurnoId"          text="ID"          prefWidth="50"/>
                                <TableColumn fx:id="colTurnoFecha"       text="Fecha"       prefWidth="140"/>
                                <TableColumn fx:id="colTurnoDuracion"    text="Duración"    prefWidth="80"/>
                                <TableColumn fx:id="colTurnoInstalacion" text="Instalación" prefWidth="120"/>
                                <TableColumn fx:id="colTurnoCapacidad"   text="Ocupación"   prefWidth="100"/>
                                <TableColumn fx:id="colTurnoEstado"      text="Estado"      prefWidth="100"/>
                                <TableColumn fx:id="colTurnoCarril"      text="Carril"      prefWidth="70"/>
                            </columns>
                        </TableView>
                        <HBox spacing="10" alignment="CENTER_LEFT">
                            <Button fx:id="btnCancelarTurno" onAction="#onCancelarTurno"
                                    text="✕  Cancelar turno"
                                    style="-fx-background-color: #E85D04; -fx-text-fill: white;
                                           -fx-padding: 8 16; -fx-background-radius: 4; -fx-cursor: hand;"/>
                            <Label fx:id="lblMsgTurnos" style="-fx-text-fill: #C44D03; -fx-font-size: 12;"/>
                        </HBox>
                    </VBox>

                    <!-- ── PANEL HISTORIAL ── -->
                    <VBox fx:id="panelHistorial" visible="false" managed="false" spacing="10"
                          style="-fx-background-color: white; -fx-background-radius: 8;
                                 -fx-effect: dropshadow(gaussian,rgba(232,93,4,0.10),6,0,0,2);
                                 -fx-padding: 20; -fx-border-color: #FFD6A5; -fx-border-radius: 8;">
                        <Label text="Historial de Turnos"
                               style="-fx-font-size: 14; -fx-font-weight: bold; -fx-text-fill: #E85D04;"/>
                        <TableView fx:id="tablaHistorial" VBox.vgrow="ALWAYS" prefHeight="380">
                            <columns>
                                <TableColumn fx:id="colHistId"          text="ID"          prefWidth="50"/>
                                <TableColumn fx:id="colHistFecha"       text="Fecha"       prefWidth="140"/>
                                <TableColumn fx:id="colHistInstalacion" text="Instalación" prefWidth="120"/>
                                <TableColumn fx:id="colHistDuracion"    text="Duración"    prefWidth="80"/>
                                <TableColumn fx:id="colHistEstado"      text="Estado"      prefWidth="110"/>
                            </columns>
                        </TableView>
                        <Label fx:id="lblMsgHistorial" text=""
                               style="-fx-text-fill: gray; -fx-font-size: 12;"/>
                    </VBox>

                    <!-- ── PANEL MIS PAGOS ── -->
                    <VBox fx:id="panelPagos" visible="false" managed="false" spacing="10"
                          style="-fx-background-color: white; -fx-background-radius: 8;
                                 -fx-effect: dropshadow(gaussian,rgba(232,93,4,0.10),6,0,0,2);
                                 -fx-padding: 20; -fx-border-color: #FFD6A5; -fx-border-radius: 8;">
                        <Label text="Mis Pagos"
                               style="-fx-font-size: 14; -fx-font-weight: bold; -fx-text-fill: #E85D04;"/>
                        <TableView fx:id="tablaPagos" VBox.vgrow="ALWAYS" prefHeight="420">
                            <columns>
                                <TableColumn fx:id="colPagoId"     text="ID"     prefWidth="55"/>
                                <TableColumn fx:id="colPagoTurno"  text="Turno"  prefWidth="75"/>
                                <TableColumn fx:id="colPagoMonto"  text="Monto"  prefWidth="120"/>
                                <TableColumn fx:id="colPagoMetodo" text="Método" prefWidth="130"/>
                                <TableColumn fx:id="colPagoEstado" text="Estado" prefWidth="120"/>
                                <TableColumn fx:id="colPagoFecha"  text="Fecha"  prefWidth="180"/>
                            </columns>
                        </TableView>
                        <Label fx:id="lblMsgPagos" text=""
                               style="-fx-text-fill: #C44D03; -fx-font-size: 12;"/>
                    </VBox>

                </VBox>
            </ScrollPane>
        </VBox>
    </center>
</BorderPane>
