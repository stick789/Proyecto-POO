<?xml version="1.0" encoding="UTF-8"?>
<?import javafx.scene.layout.BorderPane?>
<?import javafx.scene.layout.VBox?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.TableView?>
<?import javafx.scene.control.TableColumn?>
<?import javafx.scene.control.ScrollPane?>
<?import javafx.geometry.Insets?>

<BorderPane prefWidth="1280" prefHeight="800"
            xmlns="http://javafx.com/javafx/21"
            xmlns:fx="http://javafx.com/fxml/1"
            fx:controller="socratesGui.Dashboardusuariocontroller">

    <!-- ═══════════════════ LEFT SIDEBAR ═══════════════════ -->
    <left>
        <VBox prefWidth="200" style="-fx-background-color: #1a1a2e;">

            <!-- User Info -->
            <VBox spacing="6">
                <padding><Insets top="20" right="20" bottom="20" left="20"/></padding>
                <Label fx:id="lblNombreUsuario"
                       style="-fx-text-fill: white; -fx-font-size: 14; -fx-font-weight: bold;"/>
                <Label fx:id="lblEmailUsuario"
                       style="-fx-text-fill: #a0a0c0; -fx-font-size: 12;"/>
                <Label fx:id="lblCategoriaUsuario"
                       style="-fx-text-fill: #e94560; -fx-font-size: 12; -fx-background-color: #0f3460; -fx-padding: 4 8; -fx-background-radius: 4;"/>
            </VBox>

            <!-- Nav Buttons -->
            <VBox spacing="5">
                <padding><Insets top="10" right="10" bottom="10" left="10"/></padding>

                <Button fx:id="btnNavInicio"      onAction="#onInicio"      text="Inicio"
                        prefWidth="180" alignment="CENTER_LEFT"
                        style="-fx-background-color: transparent; -fx-text-fill: #a0a0c0; -fx-font-size: 13; -fx-padding: 12 20; -fx-cursor: hand;"/>
                <Button fx:id="btnNavMisTurnos"   onAction="#onMisTurnos"   text="Mis Turnos"
                        prefWidth="180" alignment="CENTER_LEFT"
                        style="-fx-background-color: transparent; -fx-text-fill: #a0a0c0; -fx-font-size: 13; -fx-padding: 12 20; -fx-cursor: hand;"/>
                <Button fx:id="btnNavMisPagos"    onAction="#onMisPagos"    text="Mis Pagos"
                        prefWidth="180" alignment="CENTER_LEFT"
                        style="-fx-background-color: transparent; -fx-text-fill: #a0a0c0; -fx-font-size: 13; -fx-padding: 12 20; -fx-cursor: hand;"/>
            </VBox>

            <!-- Spacer -->
            <VBox VBox.vgrow="ALWAYS"/>

            <!-- Logout -->
            <Button fx:id="btnLogout" onAction="#onLogout" text="Cerrar Sesión"
                    prefWidth="180"
                    style="-fx-background-color: #e94560; -fx-text-fill: white; -fx-padding: 12 20; -fx-cursor: hand;">
                <VBox.margin><Insets bottom="20" left="10" right="10"/></VBox.margin>
            </Button>
        </VBox>
    </left>

    <!-- ═══════════════════ CENTER CONTENT ═══════════════════ -->
    <center>
        <VBox style="-fx-background-color: #f4f6f9;" spacing="16">
            <padding><Insets top="20" right="20" bottom="20" left="20"/></padding>

            <!-- Header HBox -->
            <HBox alignment="CENTER_LEFT">
                <Label fx:id="lblSeccion" text="Inicio"
                       style="-fx-font-size: 24; -fx-font-weight: bold;"/>
                <HBox HBox.hgrow="ALWAYS"/>
                <Label fx:id="lblFecha"
                       style="-fx-font-size: 12; -fx-text-fill: gray;"/>
            </HBox>

            <!-- Panels Container -->
            <ScrollPane VBox.vgrow="ALWAYS" fitToWidth="true"
                        style="-fx-background: transparent; -fx-background-color: transparent;">
                <VBox spacing="16">
                    <padding><Insets top="4" right="4" bottom="4" left="4"/></padding>

                    <!-- ── PANEL INICIO ── -->
                    <VBox fx:id="panelInicio" visible="true" managed="true" spacing="20">
                        <padding><Insets top="20" right="20" bottom="20" left="20"/></padding>
                        <HBox spacing="20">
                            <!-- Tarjeta Próximo Turno -->
                            <VBox spacing="5" alignment="CENTER"
                                  style="-fx-background-color: white; -fx-background-radius: 8; -fx-effect: dropshadow(gaussian, rgba(0,0,0,0.1), 8, 0, 0, 2); -fx-padding: 20;"
                                  HBox.hgrow="ALWAYS">
                                <Label text="Próximo Turno" style="-fx-font-size: 13; -fx-text-fill: gray;"/>
                                <Label fx:id="lblProximoTurno" text="Sin turnos"
                                       style="-fx-font-size: 14; -fx-font-weight: bold; -fx-text-fill: #e94560; -fx-wrap-text: true;"/>
                            </VBox>
                            <!-- Tarjeta Turnos Activos -->
                            <VBox spacing="5" alignment="CENTER"
                                  style="-fx-background-color: white; -fx-background-radius: 8; -fx-effect: dropshadow(gaussian, rgba(0,0,0,0.1), 8, 0, 0, 2); -fx-padding: 20;"
                                  HBox.hgrow="ALWAYS">
                                <Label text="Mis Turnos Activos" style="-fx-font-size: 13; -fx-text-fill: gray;"/>
                                <Label fx:id="lblCountTurnos" text="0"
                                       style="-fx-font-size: 24; -fx-font-weight: bold; -fx-text-fill: #e94560;"/>
                            </VBox>
                            <!-- Tarjeta Pagos Pendientes -->
                            <VBox spacing="5" alignment="CENTER"
                                  style="-fx-background-color: white; -fx-background-radius: 8; -fx-effect: dropshadow(gaussian, rgba(0,0,0,0.1), 8, 0, 0, 2); -fx-padding: 20;"
                                  HBox.hgrow="ALWAYS">
                                <Label text="Mis Pagos Pendientes" style="-fx-font-size: 13; -fx-text-fill: gray;"/>
                                <Label fx:id="lblCountPagos" text="0"
                                       style="-fx-font-size: 24; -fx-font-weight: bold; -fx-text-fill: #e94560;"/>
                            </VBox>
                        </HBox>
                    </VBox>

                    <!-- ── PANEL MIS TURNOS ── -->
                    <VBox fx:id="panelTurnos" visible="false" managed="false" spacing="10"
                          style="-fx-background-color: white; -fx-background-radius: 8; -fx-effect: dropshadow(gaussian, rgba(0,0,0,0.1), 8, 0, 0, 2); -fx-padding: 20;">
                        <TableView fx:id="tablaTurnos" VBox.vgrow="ALWAYS" prefHeight="440">
                            <columns>
                                <TableColumn fx:id="colTurnoId"          text="ID"          prefWidth="55"/>
                                <TableColumn fx:id="colTurnoFecha"       text="Fecha"       prefWidth="150"/>
                                <TableColumn fx:id="colTurnoDuracion"    text="Duración"    prefWidth="85"/>
                                <TableColumn fx:id="colTurnoInstalacion" text="Instalación" prefWidth="155"/>
                                <TableColumn fx:id="colTurnoCapacidad"   text="Capacidad"   prefWidth="90"/>
                                <TableColumn fx:id="colTurnoEstado"      text="Estado"      prefWidth="105"/>
                            </columns>
                        </TableView>
                        <HBox spacing="10" alignment="CENTER_LEFT">
                            <Button fx:id="btnCancelarTurno" onAction="#onCancelarTurno" text="✕ Cancelar turno"
                                    style="-fx-background-color: #e94560; -fx-text-fill: white; -fx-padding: 8 16; -fx-background-radius: 4; -fx-cursor: hand;"/>
                            <Label fx:id="lblMsgTurnos" style="-fx-text-fill: #e94560; -fx-font-size: 12;"/>
                        </HBox>
                    </VBox>

                    <!-- ── PANEL MIS PAGOS ── -->
                    <VBox fx:id="panelPagos" visible="false" managed="false" spacing="10"
                          style="-fx-background-color: white; -fx-background-radius: 8; -fx-effect: dropshadow(gaussian, rgba(0,0,0,0.1), 8, 0, 0, 2); -fx-padding: 20;">
                        <TableView fx:id="tablaPagos" VBox.vgrow="ALWAYS" prefHeight="480">
                            <columns>
                                <TableColumn fx:id="colPagoId"      text="ID"      prefWidth="60"/>
                                <TableColumn fx:id="colPagoTurno"   text="Turno"   prefWidth="80"/>
                                <TableColumn fx:id="colPagoMonto"   text="Monto"   prefWidth="130"/>
                                <TableColumn fx:id="colPagoMetodo"  text="Método"  prefWidth="140"/>
                                <TableColumn fx:id="colPagoEstado"  text="Estado"  prefWidth="140"/>
                                <TableColumn fx:id="colPagoFecha"   text="Fecha"   prefWidth="200"/>
                            </columns>
                        </TableView>
                        <Label fx:id="lblMsgPagos" style="-fx-text-fill: #e94560; -fx-font-size: 12;"/>
                    </VBox>

                </VBox>
            </ScrollPane>
        </VBox>
    </center>
</BorderPane>
