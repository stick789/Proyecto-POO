<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>

<VBox xmlns="http://javafx.com/javafx/13" 
      xmlns:fx="http://javafx.com/fxml/1" 
      fx:controller="socratesGui.PasarelaPagosController"
      spacing="20" alignment="CENTER" 
      prefWidth="700" prefHeight="550"
      style="-fx-padding: 30;">

    <children>
        <Label text="PAGO EN LÍNEA CON TARJETA" 
               style="-fx-font-size: 18px; -fx-font-weight: bold;"/>

        <Separator/>

        <Label fx:id="lblIdTurno" text="Turno ID: ---" style="-fx-font-weight: bold;"/>
        <Label fx:id="lblTotal" text="Total a pagar: $ 0.00" style="-fx-font-weight: bold; -fx-text-fill: #2c3e50; -fx-font-size: 16px;"/>
        <Label fx:id="lblDescripcion" text="Descripción: ---"/>

        <Separator/>

        <HBox spacing="20" alignment="CENTER">
            <children>
                <Button fx:id="btnPagar" text="PAGAR CON TARJETA" 
                        style="-fx-background-color: #3498db; -fx-text-fill: white; -fx-font-weight: bold; -fx-padding: 12 30;"/>
                <Button fx:id="btnVerificar" text="VERIFICAR PAGO" 
                        style="-fx-background-color: #2ecc71; -fx-text-fill: white; -fx-font-weight: bold; -fx-padding: 12 30;"/>
                <Button fx:id="btnCerrar" text="CERRAR" 
                        style="-fx-background-color: #e74c3c; -fx-text-fill: white; -fx-font-weight: bold; -fx-padding: 12 30;"/>
            </children>
        </HBox>

        <TextArea fx:id="txtLog" prefHeight="150" editable="false" wrapText="true" 
                  promptText="Registro de eventos..."/>

        <Label text="Modo Sandbox - Tarjeta de prueba: 4111 1111 1111 1111" 
               style="-fx-font-size: 10px; -fx-text-fill: gray;"/>
    </children>
</VBox>