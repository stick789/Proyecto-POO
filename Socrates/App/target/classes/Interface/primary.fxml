<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.PasswordField?>
<?import javafx.scene.control.Separator?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.image.Image?>
<?import javafx.scene.image.ImageView?>
<?import javafx.scene.layout.VBox?>
<?import javafx.scene.text.Font?>

<VBox alignment="TOP_CENTER" prefHeight="730.0" prefWidth="920.0" spacing="10.0"
      xmlns="http://javafx.com/javafx/25"
      xmlns:fx="http://javafx.com/fxml/1"
      fx:controller="socratesGui.LoginController">

   <children>

      <!-- Logo Compensar -->
      <ImageView fitHeight="92.0" fitWidth="200.0" pickOnBounds="true" preserveRatio="true">
         <image><Image url="@compensarLog.jpg" /></image>
      </ImageView>

      <!-- Título -->
      <Label alignment="CENTER" text="BIENVENIDO">
         <font><Font name="System Bold Italic" size="22.0" /></font>
      </Label>

      <!-- Botón Ingresa con Compensar -->
      <Button fx:id="primaryButton" contentDisplay="RIGHT" graphicTextGap="3.0"
              onAction="#onLoginCompensar"
              prefHeight="72.0" prefWidth="169.0" text="Ingresa con ">
         <graphic>
            <ImageView fitHeight="95.0" fitWidth="82.0" pickOnBounds="true" preserveRatio="true">
               <image><Image url="@CompensarLogo2.png" /></image>
            </ImageView>
         </graphic>
      </Button>

      <!-- Subtítulo -->
      <Label alignment="CENTER" prefWidth="160.0" text="O puedes">
         <font><Font name="System Bold Italic" size="12.0" /></font>
      </Label>
      <Label prefWidth="160.0" text="Ingresar con Socrates">
         <font><Font name="System Bold Italic" size="15.0" /></font>
      </Label>

      <Separator prefWidth="260.0" />

      <!-- Campo correo -->
      <Label text="Correo electrónico"
             style="-fx-text-fill: #2E6B7A; -fx-font-weight: bold; -fx-font-size: 12px;" />
      <TextField fx:id="txtEmail"
                 promptText="usuario@compensar.com"
                 prefWidth="260.0"
                 style="-fx-background-color: white;
                        -fx-border-color: #2E6B7A;
                        -fx-border-radius: 6;
                        -fx-background-radius: 6;
                        -fx-padding: 7 10 7 10;
                        -fx-font-size: 13px;" />

      <!-- Campo contraseña -->
      <Label text="Contraseña"
             style="-fx-text-fill: #2E6B7A; -fx-font-weight: bold; -fx-font-size: 12px;" />
      <PasswordField fx:id="txtContrasena"
                     promptText="••••••••"
                     prefWidth="260.0"
                     style="-fx-background-color: white;
                            -fx-border-color: #2E6B7A;
                            -fx-border-radius: 6;
                            -fx-background-radius: 6;
                            -fx-padding: 7 10 7 10;
                            -fx-font-size: 13px;" />

      <!-- Mensaje de error -->
      <Label fx:id="lblError" text=""
             style="-fx-text-fill: #c0392b; -fx-font-size: 11px;"
             wrapText="true" prefWidth="260.0" />

      <!-- Botones de acción -->
        <Button mnemonicParsing="false"
              prefHeight="30.0" prefWidth="130.0"
              onAction="#onLogin"
              style="-fx-background-color: #2E6B7A; -fx-text-fill: white;
                     -fx-background-radius: 10; -fx-font-size: 13px;
                     -fx-cursor: hand;"
              text="Iniciar Sesión" />

      <Button mnemonicParsing="false"
              prefHeight="30.0" prefWidth="130.0"
              onAction="#onRegistrar"
              style="-fx-background-color: #2E6B7A; -fx-text-fill: white;
                     -fx-background-radius: 10; -fx-font-size: 13px; -fx-cursor: hand;"
              text="Registrarse" />

    

      
      <Label text="O" />
      <Button mnemonicParsing="false"
              style="-fx-background-color: #FFFFFF; -fx-border-color: #1E3A8A; -fx-border-radius: 6; -fx-background-radius: 6;">
         <graphic>
            <ImageView fitHeight="48.0" fitWidth="28.0" pickOnBounds="true" preserveRatio="true">
               <image><Image url="@GoogleIcon.png" /></image>
            </ImageView>
         </graphic>
      </Button>
      

   </children>

   <padding>
      <Insets bottom="20.0" left="20.0" right="20.0" top="20.0" />
   </padding>

</VBox>
