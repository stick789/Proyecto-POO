      <Label alignment="CENTER" text="BIENVENIDO">
         <font>
            <Font name="System Bold Italic" size="22.0" />
         </font>
      </Label>
      <Button fx:id="primaryButton" contentDisplay="RIGHT" graphicTextGap="3.0" onAction="#switchToSecondary" prefHeight="72.0" prefWidth="169.0" text="Ingresa con ">
         <graphic>
            <ImageView fitHeight="95.0" fitWidth="82.0" pickOnBounds="true" preserveRatio="true">
               <image>
                  <Image url="@CompensarLogo2.png" />
               </image>
            </ImageView>
         </graphic>
      </Button>
      <Label alignment="CENTER" prefHeight="23.0" prefWidth="109.0" text="O puedes">
         <font>
            <Font name="System Bold Italic" size="12.0" />
         </font></Label>
      <Label prefHeight="28.0" prefWidth="154.0" text="Ingresar con Socrates">
         <font>
            <Font name="System Bold Italic" size="15.0" />
         </font>
      </Label>
      <Separator prefWidth="200.0" />
      <Button mnemonicParsing="false" prefHeight="26.0" prefWidth="124.0" style="-fx-background-color: #2E6B7A; -fx-text-fill: white; -fx-background-radius: 10;" text="Registrarse" textFill="#292828" />
      <Button mnemonicParsing="false" prefHeight="26.0" prefWidth="124.0" style="-fx-background-color: #2E6B7A; -fx-text-fill: white; -fx-background-radius: 10;" text="Iniciar Sesión " />
      <Label text="O" />
      <Button mnemonicParsing="false" style="-fx-background-color: #FFFFFF; -fx-border-color: #1E3A8A;">
         <graphic>
            <ImageView fitHeight="48.0" fitWidth="28.0" pickOnBounds="true" preserveRatio="true">
               <image>
                  <Image url="@GoogleIcon.png" />
               </image>
            </ImageView>
         </graphic>
      </Button>
   </children>
   <padding>
      <Insets bottom="20.0" left="20.0" right="20.0" top="20.0" />
   </padding>
</VBox>
